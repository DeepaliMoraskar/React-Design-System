{
  "name": "@react-design-system/scss",
  "version": "1.0.0",
  "main": "index.js",
  "license": "MIT",
  "dependencies": {
    "normalize-scss": "^8.0.0"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "2.8.8",
    "stylelint": "14.16.0",
    "stylelint-config-prettier": "9.0.5",
    "stylelint-config-standard-scss": "6.1.0",
    "stylelint-scss": "4.7.0"
  },
  "scripts": {
    "lint": "stylelint './**/*.scss'",
    "lint:fix": "yarn lint --fix",
    "format": "prettier --write './**/*.scss'"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
     "**/*.scss": "yarn lint:fix"
  }
}
